APP_NAME="Terraform Review Assistant"
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/review-assistant.db
JWT_SECRET_KEY=replace-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=50
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=terraform-projects
KEY_VAULT_URL=
FERNET_KEY=

# Downstream microservice URLs (local dev defaults shown).
# In docker-compose these are set to the service DNS names.
UPLOAD_SERVICE_URL=http://localhost:8001
PARSER_SERVICE_URL=http://localhost:8002
RULES_SERVICE_URL=http://localhost:8003
AI_REVIEW_SERVICE_URL=http://localhost:8004
SCORING_SERVICE_URL=http://localhost:8005
REPORTING_SERVICE_URL=http://localhost:8006
SERVICE_TIMEOUT_SECONDS=120
